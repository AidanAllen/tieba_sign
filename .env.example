# 百度贴吧 Cookie（必填）
COOKIE=""
# 企业微信 Webhook URL（可选，不填则不推送）
WEBHOOK_URL=""

# 运行配置（留空 = 使用代码内默认值）
# 日志目录（默认：脚本目录下的 log/）
LOG_DIR="log"
# 并发线程数（默认：3）
THREADS=3
# 失败重试次数（默认：5）
RETRY=5
# 签到前最小随机延迟秒数（默认：1.0）
DELAY_MIN=1.0
# 签到前最大随机延迟秒数（默认：3.0）
DELAY_MAX=3.0
 # JSON 统计文件路径（默认：不输出）
JSON_STATS=
# 静默模式，true/false（默认：false）
QUIET=false


# ===== 代理池配置（可选，默认关闭）=====
# 是否启用代理池（true/false，默认：false）
PROXY_ENABLED=false
# 代理池 API 地址（默认：https://proxy.scdn.io/api/get_proxy.php）
PROXY_API_URL=https://proxy.scdn.io/api/get_proxy.php
# 筛选协议（http/https/socks4/socks5/all，默认：all）
PROXY_PROTOCOL=https
# 筛选国家代码（ISO 3166-1，如 CN/US，留空=不限制）
PROXY_COUNTRY_CODE=CN
